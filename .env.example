NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/naliv_emp

# Keycloak
KEYCLOAK_BASE_URL=https://sec.naliv.kz
KEYCLOAK_REALM=naliv-prod
KEYCLOAK_JWKS_URI=https://sec.naliv.kz/realms/naliv-prod/protocol/openid-connect/certs
KEYCLOAK_ISSUER=https://sec.naliv.kz/realms/naliv-prod
KEYCLOAK_INTROSPECTION_URL=https://sec.naliv.kz/realms/naliv-prod/protocol/openid-connect/token/introspect
KEYCLOAK_CLIENT_ID=naliv-emp-service
KEYCLOAK_CLIENT_SECRET=REPLACE_WITH_KEYCLOAK_SECRET
KEYCLOAK_ALLOWED_AUDIENCE=naliv-bm,naliv-njt25,naliv-web

# Service account for admin/batch actions
KEYCLOAK_SERVICE_ACCOUNT_ID=REPLACE_WITH_SERVICE_ACCOUNT_ID
KEYCLOAK_SERVICE_ACCOUNT_SECRET=REPLACE_WITH_SERVICE_ACCOUNT_SECRET

RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=1 minute
BCRYPT_ROUNDS=12

# Presence auto-offline
PRESENCE_IDLE_MINUTES=5
PRESENCE_SWEEP_INTERVAL_MS=60000

# OwnTracks webhook basic auth
OWNTRACKS_BASIC_USER=owntracks
OWNTRACKS_BASIC_PASS=change-me

# Traccar webhook basic auth
TRACCAR_BASIC_USER=traccar
TRACCAR_BASIC_PASS=change-me
TRACCAR_BASE_URL=https://traccar.example.com
TRACCAR_SYNC_INTERVAL_MS=300000
TRACCAR_POLL_INTERVAL_MS=10000
